{
  "name": "3cx-mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for 3CX Phone System — manage users, extensions, calls, queues and more via Claude",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "3cx-mcp": "./build/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "inspect": "dotenv -e .env -- npx @modelcontextprotocol/inspector node build/index.js",
    "inspect:win": "powershell -ExecutionPolicy Bypass -File scripts/inspect.ps1",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "3cx",
    "pbx",
    "telephony",
    "voip",
    "claude",
    "model-context-protocol",
    "msp",
    "phone-system"
  ],
  "author": "SSIG-IT GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SSIG-IT/3cx-mcp-server"
  }
}
