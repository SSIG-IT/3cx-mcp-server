# 3CX Connection
TCX_FQDN=your-company.my3cx.de
TCX_PORT=443
# Optional but recommended: PBX/business timezone for "today" call queries
TCX_TIMEZONE=Europe/Berlin

# XAPI Authentication (Service Principal)
# Numeric extension number from 3CX API setup (e.g. 900)
TCX_CLIENT_ID=900
# Shown once during creation — save immediately
TCX_CLIENT_SECRET=your_api_secret_here

# Legacy WebAPI (optional, not implemented yet)
TCX_WEBAPI_KEY=

# Call Control (optional, not implemented yet)
TCX_CALLCONTROL_ENABLED=false

# MCP Server
MCP_TRANSPORT=stdio
MCP_LOG_LEVEL=info

# HTTP Transport (only used when MCP_TRANSPORT=http)
# MCP_HTTP_PORT=8080
# MCP_HTTP_HOST=0.0.0.0
